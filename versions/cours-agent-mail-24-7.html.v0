<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agent Mail 24/7 — Cours technique complet</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
/* ============================================================
   TOKENS
   ============================================================ */
:root{
  --paper:#E9ECF1;
  --surface:#FFFFFF;
  --surface-2:#F4F6FA;
  --ink:#131822;
  --ink-2:#465061;
  --ink-3:#7C889A;
  --line:#D6DBE4;
  --line-2:#E4E8EF;

  --console:#0B0F16;
  --console-2:#131A25;
  --console-3:#1A2331;
  --console-line:#26303F;
  --c-ink:#CBD5E2;
  --c-mut:#7A8699;

  --accent:#3E3AE6;
  --accent-2:#7B79F5;
  --accent-soft:#ECECFD;

  --ok:#1E9E63;
  --ok-soft:#E1F3EA;
  --warn:#C9871F;
  --warn-soft:#F6ECD8;
  --danger:#D63B50;
  --danger-soft:#F9E2E5;

  --f-display:'Space Grotesk','IBM Plex Sans',system-ui,sans-serif;
  --f-body:'IBM Plex Sans',system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;
  --f-mono:'IBM Plex Mono',ui-monospace,SFMono-Regular,Menlo,monospace;

  --nav-w:270px;
  --maxw:820px;
  --radius:14px;
}

*{box-sizing:border-box}
html{scroll-behavior:smooth}
@media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}}
body{
  margin:0;
  background:var(--paper);
  color:var(--ink);
  font-family:var(--f-body);
  font-size:16px;
  line-height:1.65;
  -webkit-font-smoothing:antialiased;
  text-rendering:optimizeLegibility;
}
a{color:var(--accent);text-decoration:none}
a:hover{text-decoration:underline}

/* subtle blueprint grid on the paper */
body::before{
  content:"";position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(var(--line-2) 1px,transparent 1px),
                   linear-gradient(90deg,var(--line-2) 1px,transparent 1px);
  background-size:52px 52px;
  -webkit-mask-image:radial-gradient(120% 90% at 70% 0%,#000 0%,transparent 65%);
          mask-image:radial-gradient(120% 90% at 70% 0%,#000 0%,transparent 65%);
  opacity:.5;
}

/* ============================================================
   ACCESSIBILITY
   ============================================================ */
.skip{position:absolute;left:-999px;top:0;background:var(--ink);color:#fff;
  padding:10px 16px;z-index:200;border-radius:0 0 8px 0;font-family:var(--f-mono);font-size:13px}
.skip:focus{left:0}
:focus-visible{outline:2px solid var(--accent);outline-offset:3px;border-radius:4px}

/* ============================================================
   PROGRESS
   ============================================================ */
.progress{position:fixed;top:0;left:0;height:3px;width:0%;
  background:linear-gradient(90deg,var(--accent),var(--accent-2));z-index:120;transition:width .1s linear}

/* ============================================================
   TOP STRIP
   ============================================================ */
.strip{
  position:sticky;top:0;z-index:100;
  background:var(--console);color:var(--c-ink);
  border-bottom:1px solid var(--console-line);
  display:flex;align-items:center;gap:14px;
  padding:9px clamp(14px,3vw,26px);
  font-family:var(--f-mono);font-size:12px;letter-spacing:.02em;
}
.strip__live{display:inline-flex;align-items:center;gap:7px;color:var(--ok);font-weight:600}
.pulse{width:8px;height:8px;border-radius:50%;background:var(--ok);box-shadow:0 0 0 0 rgba(30,158,99,.6);animation:pulse 2.4s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(30,158,99,.5)}70%{box-shadow:0 0 0 7px rgba(30,158,99,0)}100%{box-shadow:0 0 0 0 rgba(30,158,99,0)}}
.strip__name{color:#fff;font-weight:600;letter-spacing:.04em}
.strip__sep{color:var(--c-mut)}
.strip__phases{margin-left:auto;display:flex;gap:6px}
.pchip{font-size:11px;padding:2px 8px;border-radius:20px;border:1px solid var(--console-line);color:var(--c-mut)}
.pchip--on{color:#fff;border-color:var(--accent-2);background:rgba(123,121,245,.14)}
.strip__menu{display:none}

/* ============================================================
   SHELL
   ============================================================ */
.shell{position:relative;z-index:1;display:grid;grid-template-columns:var(--nav-w) 1fr;
  max-width:1240px;margin:0 auto;align-items:start}

/* ---- SIDE NAV ---- */
.nav{
  position:sticky;top:41px;align-self:start;height:calc(100vh - 41px);
  overflow-y:auto;padding:26px 14px 40px 22px;
  border-right:1px solid var(--line);
}
.nav__label{font-family:var(--f-mono);font-size:11px;letter-spacing:.14em;
  text-transform:uppercase;color:var(--ink-3);margin:0 0 12px 8px}
.nav ol{list-style:none;margin:0;padding:0;counter-reset:mod}
.nav li{margin:1px 0}
.nav a{
  display:grid;grid-template-columns:34px 1fr;align-items:baseline;gap:2px;
  padding:6px 8px;border-radius:8px;color:var(--ink-2);
  font-size:13.5px;line-height:1.3;border-left:2px solid transparent;
}
.nav a:hover{background:var(--surface);text-decoration:none;color:var(--ink)}
.nav a .num{font-family:var(--f-mono);font-size:11px;color:var(--ink-3)}
.nav a.active{background:var(--accent-soft);color:var(--ink);font-weight:600;border-left-color:var(--accent)}
.nav a.active .num{color:var(--accent)}
.nav__foot{margin-top:22px;padding:12px;border:1px dashed var(--line);border-radius:10px;
  font-family:var(--f-mono);font-size:11px;color:var(--ink-3);line-height:1.7}

/* ============================================================
   MAIN
   ============================================================ */
.main{min-width:0;padding:0 clamp(18px,4vw,60px) 90px}
.wrap{max-width:var(--maxw);margin:0 auto}

/* ---- HERO ---- */
.hero{margin:34px auto 46px;max-width:940px}
.hero__eye{font-family:var(--f-mono);font-size:12px;letter-spacing:.16em;
  text-transform:uppercase;color:var(--accent);margin-bottom:16px;display:flex;gap:12px;flex-wrap:wrap}
.hero__eye b{color:var(--ink-3);font-weight:500}
.hero h1{
  font-family:var(--f-display);font-weight:700;
  font-size:clamp(2.3rem,6vw,4rem);line-height:1.02;letter-spacing:-.02em;margin:0 0 20px;
}
.hero h1 .tag{color:var(--accent)}
.hero__lead{font-size:clamp(1.05rem,2.2vw,1.28rem);color:var(--ink-2);max-width:620px;margin:0 0 30px}

/* ---- CONSOLE (signature) ---- */
.console{background:var(--console);border:1px solid var(--console-line);border-radius:16px;
  overflow:hidden;box-shadow:0 24px 60px -30px rgba(11,15,22,.6);color:var(--c-ink)}
.console__bar{display:flex;align-items:center;gap:9px;padding:11px 16px;
  border-bottom:1px solid var(--console-line);background:var(--console-2)}
.tl{width:11px;height:11px;border-radius:50%}
.tl--r{background:#F0655C}.tl--y{background:#E7B33E}.tl--g{background:#4FB471}
.console__ttl{font-family:var(--f-mono);font-size:12px;color:var(--c-mut);margin-left:6px}
.console__live{margin-left:auto;font-family:var(--f-mono);font-size:11px;color:var(--ok);
  display:inline-flex;align-items:center;gap:6px}
.console__body{display:grid;grid-template-columns:1fr 1fr;gap:0}
.health{padding:16px 18px;border-right:1px solid var(--console-line)}
.health__h,.log__h{font-family:var(--f-mono);font-size:10.5px;letter-spacing:.13em;
  text-transform:uppercase;color:var(--c-mut);margin:0 0 12px}
.hrow{display:flex;align-items:center;gap:10px;padding:5px 0;font-family:var(--f-mono);font-size:12.5px}
.hrow .k{color:var(--c-ink);flex:1}
.hrow .v{color:var(--c-mut);font-size:11.5px}
.sd{width:8px;height:8px;border-radius:50%;flex:none}
.sd--ok{background:var(--ok);box-shadow:0 0 8px rgba(30,158,99,.7)}
.sd--warn{background:var(--warn);box-shadow:0 0 8px rgba(201,135,31,.7)}
.sd--danger{background:var(--danger);box-shadow:0 0 8px rgba(214,59,80,.7)}
.blink{animation:blink 1.1s steps(2) infinite}
@keyframes blink{50%{opacity:.25}}
.log{padding:16px 18px;min-height:210px}
.log__stream{font-family:var(--f-mono);font-size:11.6px;line-height:1.9;color:var(--c-mut)}
.log__stream .line{display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.log__stream .t{color:#5C6b82}
.log__stream .ok{color:var(--ok)}
.log__stream .warn{color:var(--warn)}
.log__stream .dng{color:var(--danger);font-weight:600}
.log__stream .ac{color:var(--accent-2)}
.console__phases{display:flex;border-top:1px solid var(--console-line)}
.cph{flex:1;padding:11px 14px;font-family:var(--f-mono);font-size:11.5px;color:var(--c-mut);
  border-right:1px solid var(--console-line);display:flex;gap:9px;align-items:center}
.cph:last-child{border-right:0}
.cph b{color:#fff}
.cph .badge{font-size:10px;padding:1px 7px;border-radius:12px;background:rgba(123,121,245,.16);color:var(--accent-2)}

/* ---- hero meta chips ---- */
.hchips{display:flex;flex-wrap:wrap;gap:8px;margin-top:22px}
.hchip{font-family:var(--f-mono);font-size:11.5px;color:var(--ink-2);background:var(--surface);
  border:1px solid var(--line);border-radius:20px;padding:5px 12px}
.hchip b{color:var(--ink)}

/* ============================================================
   SECTIONS
   ============================================================ */
.module{padding-top:56px;margin-top:6px}
.module__head{border-top:2px solid var(--ink);padding-top:18px;margin-bottom:26px}
.module__code{font-family:var(--f-mono);font-size:12px;letter-spacing:.13em;text-transform:uppercase;
  color:var(--accent);display:flex;gap:12px;align-items:center;margin-bottom:14px}
.module__code .ph{font-size:10.5px;color:var(--ink-3);border:1px solid var(--line);
  border-radius:12px;padding:1px 9px;letter-spacing:.06em}
.module h2{font-family:var(--f-display);font-weight:700;font-size:clamp(1.6rem,3.6vw,2.3rem);
  line-height:1.08;letter-spacing:-.015em;margin:0 0 8px}
.module__sub{color:var(--ink-2);font-size:1.05rem;margin:0}

h3{font-family:var(--f-display);font-weight:600;font-size:1.28rem;letter-spacing:-.01em;
  margin:38px 0 12px}
h4{font-family:var(--f-display);font-weight:600;font-size:1.06rem;margin:26px 0 8px}
p{margin:0 0 16px}
strong{font-weight:600;color:var(--ink)}
.lead-p{font-size:1.1rem;color:var(--ink-2)}

ul,ol.list{margin:0 0 18px;padding-left:22px}
li{margin:6px 0}
.tick{list-style:none;padding-left:0}
.tick li{position:relative;padding-left:28px;margin:9px 0}
.tick li::before{content:"";position:absolute;left:4px;top:9px;width:9px;height:9px;border-radius:2px;
  background:var(--accent)}
.tick.tick--no li::before{background:var(--danger)}
.tick.tick--ok li::before{background:var(--ok)}

/* ---- objectives card ---- */
.obj{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);
  padding:20px 22px;margin:22px 0}
.obj__t{font-family:var(--f-mono);font-size:11px;letter-spacing:.13em;text-transform:uppercase;
  color:var(--ink-3);margin:0 0 12px;display:flex;align-items:center;gap:8px}
.obj__t::before{content:"◎";color:var(--accent)}
.obj ul{margin:0;padding-left:0;list-style:none}
.obj li{padding-left:26px;position:relative;margin:8px 0;color:var(--ink-2)}
.obj li::before{content:"→";position:absolute;left:0;color:var(--accent);font-family:var(--f-mono)}

/* ---- callouts ---- */
.call{border:1px solid var(--line);border-left-width:4px;border-radius:10px;
  padding:16px 18px;margin:22px 0;background:var(--surface);font-size:.98rem}
.call__t{font-family:var(--f-mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;
  font-weight:600;margin:0 0 6px;display:flex;align-items:center;gap:8px}
.call p:last-child{margin-bottom:0}
.call--key{border-left-color:var(--accent);background:var(--accent-soft)}
.call--key .call__t{color:var(--accent)}
.call--sec{border-left-color:var(--ink);background:var(--surface-2)}
.call--sec .call__t{color:var(--ink)}
.call--warn{border-left-color:var(--warn);background:var(--warn-soft)}
.call--warn .call__t{color:#8a5e10}
.call--danger{border-left-color:var(--danger);background:var(--danger-soft)}
.call--danger .call__t{color:#a52537}

/* ---- tables ---- */
.tbl-wrap{overflow-x:auto;margin:20px 0;border:1px solid var(--line);border-radius:12px;background:var(--surface)}
table{border-collapse:collapse;width:100%;font-size:14px;min-width:440px}
th,td{text-align:left;padding:11px 15px;border-bottom:1px solid var(--line-2);vertical-align:top}
th{font-family:var(--f-mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;
  color:var(--ink-3);background:var(--surface-2);font-weight:600;position:sticky;top:0}
tr:last-child td{border-bottom:0}
td code{white-space:nowrap}
.cell-yes{color:var(--ok);font-weight:600}
.cell-no{color:var(--danger);font-weight:600}
.badge-tag{display:inline-block;font-family:var(--f-mono);font-size:10.5px;padding:2px 8px;border-radius:12px;
  font-weight:600;letter-spacing:.03em}
.b-ok{background:var(--ok-soft);color:#0f6b41}
.b-warn{background:var(--warn-soft);color:#8a5e10}
.b-dng{background:var(--danger-soft);color:#a52537}
.b-neu{background:var(--accent-soft);color:var(--accent)}

/* ---- code ---- */
pre{background:var(--console);color:var(--c-ink);border:1px solid var(--console-line);
  border-radius:12px;padding:16px 18px;overflow-x:auto;margin:20px 0;
  font-family:var(--f-mono);font-size:13px;line-height:1.65}
pre .cm{color:#6B788D}
pre .kw{color:#8C89FF}
pre .st{color:#7FCF9A}
pre .nm{color:#E6B450}
pre .fn{color:#6FC3E8}
code{font-family:var(--f-mono);font-size:.88em;background:var(--surface-2);
  border:1px solid var(--line-2);border-radius:5px;padding:1.5px 5px;color:var(--ink)}
pre code{background:none;border:0;padding:0;font-size:1em;color:inherit}

.codecap{font-family:var(--f-mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;
  color:var(--ink-3);margin:22px 0 -8px;display:flex;align-items:center;gap:8px}
.codecap::before{content:"▚";color:var(--accent)}

/* ============================================================
   DIAGRAMS
   ============================================================ */
.diagram{background:var(--surface);border:1px solid var(--line);border-radius:14px;
  padding:22px;margin:24px 0}
.dia__cap{font-family:var(--f-mono);font-size:11px;letter-spacing:.09em;text-transform:uppercase;
  color:var(--ink-3);margin:14px 0 0;text-align:center}

/* pipeline (horizontal) */
.pipe{display:flex;align-items:stretch;gap:0;flex-wrap:wrap}
.node{flex:1;min-width:140px;background:var(--surface-2);border:1px solid var(--line);
  border-radius:10px;padding:13px 14px}
.node__k{font-family:var(--f-mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--accent)}
.node__t{font-family:var(--f-display);font-weight:600;font-size:.98rem;margin:3px 0 2px}
.node__d{font-size:12.5px;color:var(--ink-2);line-height:1.45}
.arrow{align-self:center;color:var(--ink-3);font-family:var(--f-mono);font-size:20px;padding:0 6px;flex:none}
.arrow--down{transform:rotate(90deg)}

/* containment (vertical stack) */
.stack{display:flex;flex-direction:column;align-items:stretch;gap:0}
.slab{border:1px solid var(--line);border-radius:10px;padding:13px 16px;background:var(--surface-2)}
.slab--host{border-style:dashed}
.slab--vm{border-color:var(--accent);background:var(--accent-soft)}
.slab--cont{border-color:var(--ink);background:#fff;margin:10px 0}
.slab__k{font-family:var(--f-mono);font-size:10.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3)}
.slab__k b{color:var(--accent)}
.vsep{align-self:center;color:var(--ink-3);font-size:18px;padding:5px 0}

/* phase ladder */
.ladder{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:24px 0}
.rung{background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:18px;position:relative;overflow:hidden}
.rung::before{content:"";position:absolute;left:0;top:0;bottom:0;width:4px}
.rung--0::before{background:var(--ink-3)}
.rung--1::before{background:var(--accent)}
.rung--2::before{background:var(--ok)}
.rung__p{font-family:var(--f-mono);font-weight:600;font-size:12px;letter-spacing:.1em;color:var(--ink-3)}
.rung--1 .rung__p{color:var(--accent)}
.rung--2 .rung__p{color:var(--ok)}
.rung__t{font-family:var(--f-display);font-weight:700;font-size:1.15rem;margin:6px 0 8px}
.rung__d{font-size:13px;color:var(--ink-2);line-height:1.5;margin:0}
.rung__verb{font-family:var(--f-mono);font-size:11px;text-transform:uppercase;letter-spacing:.08em;
  color:var(--ink);margin-top:12px;padding-top:10px;border-top:1px solid var(--line-2)}

/* dependency / agents */
.agents{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:12px;margin:22px 0}
.agent{background:var(--surface);border:1px solid var(--line);border-radius:12px;padding:14px 15px}
.agent__n{font-family:var(--f-mono);font-size:11px;color:var(--accent);letter-spacing:.02em}
.agent__t{font-family:var(--f-display);font-weight:600;font-size:.98rem;margin:2px 0 4px}
.agent__d{font-size:12.5px;color:var(--ink-2);line-height:1.45;margin:0 0 8px}
.agent__dep{font-family:var(--f-mono);font-size:10.5px;color:var(--ink-3)}
.agent__ph{position:absolute}

/* metric row */
.stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;margin:22px 0}
.stat{background:var(--surface);border:1px solid var(--line);border-radius:12px;padding:16px}
.stat__n{font-family:var(--f-display);font-weight:700;font-size:1.7rem;line-height:1;color:var(--ink)}
.stat__n small{font-size:.9rem;color:var(--ink-3);font-weight:500}
.stat__l{font-family:var(--f-mono);font-size:11px;color:var(--ink-3);margin-top:6px;letter-spacing:.03em}

/* recap / glossary */
.recap{background:var(--console);color:var(--c-ink);border-radius:18px;padding:clamp(24px,4vw,40px);
  margin:60px auto 0;max-width:940px}
.recap h2{font-family:var(--f-display);color:#fff;font-size:clamp(1.5rem,3.4vw,2.1rem);margin:0 0 10px;letter-spacing:-.01em}
.recap__eye{font-family:var(--f-mono);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent-2);margin-bottom:14px}
.recap p{color:var(--c-mut)}
.recap ol{counter-reset:r;list-style:none;padding:0;margin:22px 0 0;display:grid;gap:2px}
.recap ol li{counter-increment:r;position:relative;padding:12px 0 12px 46px;border-top:1px solid var(--console-line);color:var(--c-ink);font-size:.98rem}
.recap ol li::before{content:counter(r,decimal-leading-zero);position:absolute;left:0;top:12px;
  font-family:var(--f-mono);font-size:12px;color:var(--accent-2)}

.gloss{margin:40px auto 0;max-width:940px}
.gloss dl{display:grid;grid-template-columns:180px 1fr;gap:0;border-top:1px solid var(--line)}
.gloss dt{font-family:var(--f-mono);font-size:13px;color:var(--accent);padding:12px 0;border-bottom:1px solid var(--line-2);font-weight:600}
.gloss dd{margin:0;padding:12px 0;border-bottom:1px solid var(--line-2);color:var(--ink-2);font-size:14px}

.foot{max-width:940px;margin:52px auto 0;padding-top:22px;border-top:1px solid var(--line);
  font-family:var(--f-mono);font-size:12px;color:var(--ink-3);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px}

/* details */
details{border:1px solid var(--line);border-radius:10px;background:var(--surface);margin:18px 0;overflow:hidden}
details>summary{cursor:pointer;padding:14px 18px;font-family:var(--f-display);font-weight:600;
  list-style:none;display:flex;align-items:center;gap:10px}
details>summary::-webkit-details-marker{display:none}
details>summary::before{content:"+";font-family:var(--f-mono);color:var(--accent);font-size:18px}
details[open]>summary::before{content:"−"}
details .det-body{padding:0 18px 6px}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width:900px){
  :root{--nav-w:0px}
  .shell{grid-template-columns:1fr}
  .nav{position:fixed;top:0;left:0;height:100vh;width:290px;max-width:86vw;z-index:150;
    background:var(--paper);transform:translateX(-102%);transition:transform .28s ease;
    padding-top:60px;box-shadow:0 0 60px rgba(0,0,0,.2)}
  body.nav-open .nav{transform:translateX(0)}
  .strip__menu{display:inline-flex;align-items:center;gap:8px;background:none;border:1px solid var(--console-line);
    color:var(--c-ink);font-family:var(--f-mono);font-size:12px;padding:5px 11px;border-radius:8px;cursor:pointer;margin-right:4px}
  .strip__phases{display:none}
  .nav-scrim{position:fixed;inset:0;background:rgba(11,15,22,.5);z-index:140;opacity:0;pointer-events:none;transition:opacity .28s}
  body.nav-open .nav-scrim{opacity:1;pointer-events:auto}
  .console__body{grid-template-columns:1fr}
  .health{border-right:0;border-bottom:1px solid var(--console-line)}
  .console__phases{flex-direction:column}
  .cph{border-right:0;border-bottom:1px solid var(--console-line)}
  .cph:last-child{border-bottom:0}
  .ladder{grid-template-columns:1fr}
  .gloss dl{grid-template-columns:1fr}
  .gloss dt{padding-bottom:2px;border-bottom:0}
  .gloss dd{padding-top:2px}
}
@media (min-width:901px){.nav-scrim{display:none}}

@media (prefers-reduced-motion:reduce){
  *{animation:none!important;transition:none!important}
}
</style>
</head>
<body>
