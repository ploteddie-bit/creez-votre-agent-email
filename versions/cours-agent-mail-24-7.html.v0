<div class="shell">
<!-- ===== SIDE NAV ===== -->
<nav class="nav" id="nav" aria-label="Sommaire du cours">
  <p class="nav__label">Programme</p>
  <ol>
    <li><a href="#m0"><span class="num">00</span><span>Introduction &amp; philosophie</span></a></li>
    <li><a href="#m1"><span class="num">01</span><span>Vision &amp; principes</span></a></li>
    <li><a href="#m2"><span class="num">02</span><span>Architecture d'ensemble</span></a></li>
    <li><a href="#m3"><span class="num">03</span><span>Sécurité &amp; anti-injection</span></a></li>
    <li><a href="#m4"><span class="num">04</span><span>Le sandbox Firecracker</span></a></li>
    <li><a href="#m5"><span class="num">05</span><span>Connexion Gmail</span></a></li>
    <li><a href="#m6"><span class="num">06</span><span>Base de données</span></a></li>
    <li><a href="#m7"><span class="num">07</span><span>Embeddings &amp; RAG</span></a></li>
